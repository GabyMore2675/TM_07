<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Entrada -->
    <EditText
        android:id="@+id/editTextTemp"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:hint="Ingrese temperatura"
        android:inputType="numberDecimal"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Opciones -->
    <RadioGroup
        android:id="@+id/radioGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toBottomOf="@id/editTextTemp"
        app:layout_constraintStart_toStartOf="parent">

        <RadioButton
            android:id="@+id/radioCtoF"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Celsius a Fahrenheit"
            android:checked="true"/>

        <RadioButton
            android:id="@+id/radioFtoC"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fahrenheit a Celsius"/>
    </RadioGroup>

    <!-- Botón -->
    <Button
        android:id="@+id/btnConvertir"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Convertir"
        android:onClick="miClicManejador"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>